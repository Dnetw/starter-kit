{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "dnetw/starter-kit",
    "type": "project",
    "description": "Laravel starter kit for the dnetw ecosystem. Ships the dnetw/core + dnetw/admin baseline (auth, admin surface, sidebar, settings, dashboard). Layer additional dnetw packages (calendar, attachments, comments, tags, …) via `composer require dnetw/<package> && php artisan dnetw:install`.",
    "keywords": [
        "laravel",
        "framework",
        "dnetw",
        "starter-kit",
        "livewire",
        "flux"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "dnetw/admin": "^0.3.25",
        "dnetw/core": "^0.7.30",
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.17",
        "laravel/tinker": "^3.0",
        "livewire/flux": "^2.13.1",
        "livewire/flux-pro": "^2.14",
        "livewire/livewire": "^4.1",
        "livewire/volt": "^1.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@lint:check",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan storage:link --force --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [],
            "installer": {
                "post-create-project": []
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "flux-pro",
            "type": "composer",
            "url": "https://composer.fluxui.dev"
        },
        {
            "type": "vcs",
            "url": "https://github.com/Dnetw/core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/Dnetw/admin"
        },
        {
            "type": "vcs",
            "url": "https://github.com/Dnetw/attachments"
        },
        {
            "type": "vcs",
            "url": "https://github.com/Dnetw/comments"
        }
    ]
}
